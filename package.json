{
  "name": "pi-lsp-lite",
  "version": "0.4.0",
  "description": "LSP diagnostics for pi — errors and warnings on every edit, same turn. Go, Rust, TypeScript, Python, C/C++.",
  "type": "module",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mcphailtom/pi-lsp-lite.git"
  },
  "homepage": "https://github.com/mcphailtom/pi-lsp-lite",
  "bugs": "https://github.com/mcphailtom/pi-lsp-lite/issues",
  "keywords": [
    "pi-package",
    "pi-extension",
    "lsp",
    "gopls",
    "rust-analyzer",
    "typescript-language-server",
    "pylsp",
    "clangd",
    "python",
    "cpp"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "cross-spawn": "^7.0.6",
    "vscode-languageserver-protocol": "~3.18.1",
    "which": "^2.0.2"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^22.0.0",
    "@types/which": "^2.0.2",
    "cross-env": "^7.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "test:integration": "cross-env INTEGRATION=1 tsx --test test/*.test.ts test/integration/*.test.ts"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
